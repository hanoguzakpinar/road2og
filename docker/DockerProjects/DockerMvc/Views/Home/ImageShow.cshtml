@{
    ViewData["Title"] = "ImageShow";
}
@model IEnumerable<string>

<h1>Image Show</h1>

@foreach (var item in Model)
{
    <img src="~/images/@item" style="width:100px; height:100px; border:1px solid red;" />
    <h1>@item</h1>
}

<form asp-action="ImageShow" method="post">
<input type="text" name="imageId">
<button type="submit">Sil</button>
</form>